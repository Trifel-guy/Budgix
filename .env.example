# ── App ──────────────────────────────────
APP_NAME=Budgix
ENVIRONMENT=development        # development | integration | staging | production
DEBUG=false

# ── Security ─────────────────────────────
SECRET_KEY=change-me-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=budgix
POSTGRES_PASSWORD=budgix_secret
POSTGRES_DB=budgix

# ── CORS ─────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# ── Frontend ─────────────────────────────
VITE_API_URL=/api/v1
